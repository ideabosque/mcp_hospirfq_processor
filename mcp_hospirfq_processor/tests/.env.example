# =============================================================================
# MCP HospiRFQ Processor — Test Environment Example
# =============================================================================
# Copy this file to .env and fill in values for your environment:
#
#   cp .env.example .env
#
# This project calls the ai_rfq_engine GraphQL API through the
# silvaengine_gateway (not directly to AWS API Gateway).  The gateway
# enforces JWT Bearer auth and routes to ai_rfq_engine in-process.
#
# Start the gateway before running integration tests:
#   python -m silvaengine_gateway.tests.run_daemon
#
# Unit tests mock _execute_graphql_query so no gateway is required.
# Integration tests (future) will use these values to reach the gateway.
# =============================================================================

# --- Package resolution ------------------------------------------------------
# Absolute path to the silvaengine source root (added to sys.path so
# mcp_hospirfq_processor and silvaengine_utility are importable).
# Absolute path to the silvaengine monorepo root (where silvaengine_utility,
# silvaengine_constants, ai_rfq_engine, etc. live).
base_dir=C:\Users\bibo7\gitrepo\silvaengine

# --- Gateway auth (login to obtain JWT Bearer token) -------------------------
# These feed the GraphQLClient settings (gateway_base_url / token_username /
# token_password / gateway_token) so the module authenticates with the
# silvaengine_gateway itself — used in production, not just for tests. When
# GATEWAY_BASE_URL is set the client sends "Authorization: Bearer <token>";
# otherwise it falls back to AWS API Gateway x-api-key auth.
GATEWAY_BASE_URL=http://localhost:8765
TOKEN_USERNAME=admin
TOKEN_PASSWORD=change-me
# Optional: pre-generated permanent token (skips /auth/token login)
# GATEWAY_TOKEN=

# --- Tenant routing ---------------------------------------------------------
# endpoint_id and part_id are interpolated into the gateway route path:
#   /{endpoint_id}/{part_id}/ai_rfq_graphql
endpoint_id=gpt
part_id=nestaging

# --- AI RFQ Engine (via gateway) --------------------------------------------
# The GraphQL module endpoint points at the gateway route, not the
# backend directly.  The gateway forwards to ai_rfq_engine in-process.
# {endpoint_id} and {part_id} are interpolated at runtime.
AI_RFQ_ENGINE_CLASS_NAME=AIRFQEngine
AI_RFQ_ENGINE_ENDPOINT=http://localhost:8765/{endpoint_id}/{part_id}/ai_rfq_graphql
# When going through the gateway, auth uses Bearer JWT (see above).
# The x_api_key field is not used by the gateway but is kept for the
# GraphQLClient constructor — set to any non-empty placeholder.
AI_RFQ_ENGINE_X_API_KEY=placeholder

# --- Optional processor settings --------------------------------------------
# JSON map of provider ID → sales rep email
SALES_REP_EMAILS={}
# Days to filter batch expiration (default: 90)
DEFAULT_BATCH_EXPIRATION_FILTER_DAYS=90
# Day of month for scheduled installments (default: 15)
INSTALLMENT_SCHEDULED_DAY=15